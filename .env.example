# ─── NeuroLearn Environment Variables ──────────────────────────
# Copy to .env.local:  cp .env.example .env.local
# NEVER commit .env.local — it is excluded in .gitignore
#
# All VITE_* variables are exposed to the browser bundle.
# Non-prefixed variables are server-side only (Edge Functions).
# ───────────────────────────────────────────────────────────────

# ─── Supabase (required) ──────────────────────────────────────
# Project Settings → API  (https://supabase.com/dashboard)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Server-side only — NEVER prefix with VITE_
# Used by Edge Functions & migrations (not bundled into client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_DB_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# ─── App ──────────────────────────────────────────────────────
VITE_APP_URL=http://localhost:5173
VITE_APP_ENV=development

# ─── OAuth Redirect (set in Supabase Auth → URL Configuration) ─
# Local:      http://localhost:5173/auth/callback
# Production: https://neurolearn-one.vercel.app/auth/callback

# ─── RACA Feature Flags ─────────────────────────────────────────
# Each layer can be independently enabled. Set to "true" to activate.
# Rollout order enforced by architecture: guardrails must be on before agents.
# Set all to "true" in Vercel environment settings for production (REQ-18-09).
#
# Layer dependency order:
#   1. runtime       — session lifecycle, audit trail (prerequisite for all)
#   2. cognitiveFsm  — 9-state machine (requires runtime)
#   3. guardrails    — constraint enforcement (enable BEFORE agents)
#   4. audit         — compliance persistence (enable BEFORE agents)
#   5. agentRouter   — state→agent mapping (requires cognitiveFsm)
#   6. agents        — AI invocations (requires guardrails + audit + agentRouter)
#   7. epistemicMonitoring — TRACE scoring (requires runtime)
#   8. adaptation    — difficulty adjustment (requires epistemicMonitoring)
#
# Development defaults:
#   Stable layers (runtime, fsm, router, guardrails, epistemic, adaptation)
#   are enabled by default in development even when these vars are absent.
#   Only flags that require external services (agents, audit) default to false.
#   You can still override any flag explicitly here.
VITE_RACA_ENABLE_RUNTIME=true
VITE_RACA_ENABLE_COGNITIVE_FSM=true
VITE_RACA_ENABLE_AGENT_ROUTER=true
# Requires AI provider key + deployed Edge Function — opt in explicitly:
VITE_RACA_ENABLE_AGENTS=false
VITE_RACA_ENABLE_EPISTEMIC=true
VITE_RACA_ENABLE_GUARDRAILS=true
# Requires Supabase write access — opt in explicitly:
VITE_RACA_ENABLE_AUDIT=false
VITE_RACA_ENABLE_ADAPTATION=true
#
# Production values (set these in Vercel dashboard → Settings → Environment Variables):
# VITE_RACA_ENABLE_RUNTIME=true
# VITE_RACA_ENABLE_COGNITIVE_FSM=true
# VITE_RACA_ENABLE_GUARDRAILS=true
# VITE_RACA_ENABLE_AUDIT=true
# VITE_RACA_ENABLE_AGENT_ROUTER=true
# VITE_RACA_ENABLE_AGENTS=true
# VITE_RACA_ENABLE_EPISTEMIC=true
# VITE_RACA_ENABLE_ADAPTATION=true

# ─── Observability ──────────────────────────────────────────
VITE_SENTRY_DSN=                     # Sentry DSN (from Sentry project settings)
VITE_SENTRY_ENVIRONMENT=development  # development | staging | production
VITE_VERCEL_ANALYTICS_ID=           # Vercel Analytics ID (auto-injected by Vercel)

# ─── Logging ─────────────────────────────────────────────────
# VITE_LOG_LEVEL=info

# ─── AI Provider (Edge Functions only) ──────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# RACA_AI_PROVIDER=anthropic
# RACA_AI_MODEL=claude-sonnet-4-6
